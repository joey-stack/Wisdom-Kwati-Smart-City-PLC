        '  page\n' +
        '}) => {\n' +
        "  await page.goto('/house-types/white-pearl');\n" +
        '\n' +
        '  // Inject CSS to bypass GSAP scroll reveal hiding\n' +
        '  await page.addStyleTag({\n' +
        '    content: `\n' +
        '      .reveal-on-scroll, .wksc-reveal {\n' +
        '        opacity: 1 !important;\n' +
        '        visibility: visible !important;\n' +
        '        transform: none !important;\n' +
        '        filter: none !important;\n' +
        '        pointer-events: auto !important;\n' +
        '      }\n' +
        '    `\n' +
        '  });\n' +
        '\n' +
        "  // Check if we hit the fallback 'not found' screen\n" +
        "  const notFoundHeading = page.locator('text=SPECIFICATION NOT FOUND');\n" +
        '  const isNotFound = await notFoundHeading.isVisible();\n' +
        '  if (isNotFound) {\n' +
        '    // If not found (e.g. database not seeded locally), verify the fallback UI behaves correctly\n' +
        "    await (0, _test.expect)(page.getByRole('link', {\n" +
        "      name: 'BACK TO LISTING'\n" +
        '    })).toBeVisible();\n' +
        '  } else {\n' +
        '    // Otherwise, verify the full property specification page renders\n' +
        "    await (0, _test.expect)(page.locator('h1.hd-hero-title')).toBeVisible();\n" +
