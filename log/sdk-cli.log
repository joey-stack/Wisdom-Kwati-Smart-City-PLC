        '  // Inject CSS to bypass GSAP scroll reveal hiding\n' +
        '  await page.addStyleTag({\n' +
        '    content: `\n' +
        '      .reveal-on-scroll, .wksc-reveal {\n' +
        '        opacity: 1 !important;\n' +
        '        visibility: visible !important;\n' +
        '        transform: none !important;\n' +
        '        filter: none !important;\n' +
        '        pointer-events: auto !important;\n' +
        '      }\n' +
        '    `\n' +
        '  });\n' +
        '\n' +
        '  // Expect the main headline to be visible and contain the brand promise\n' +
        "  const headline = page.locator('h1.headline');\n" +
        '  await (0, _test.expect)(headline).toBeVisible();\n' +
        '  await (0, _test.expect)(headline).toContainText(/Dream Large|Live Smart/i);\n' +
        '\n' +
        "  // Hero CTA or Nav CTA must exist and contain 'REQUEST A SITE VISIT'\n" +
        "  const ctaButton = page.locator('button.nav-cta, button.cta-button').first();\n" +
