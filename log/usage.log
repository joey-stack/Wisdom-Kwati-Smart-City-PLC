    '}) => {\n' +
    "  await page.goto('/house-types', {\n" +
    "    waitUntil: 'domcontentloaded'\n" +
    '  });\n' +
    '\n' +
    '  // Inject CSS to bypass GSAP scroll reveal hiding\n' +
    '  await page.addStyleTag({\n' +
    '    content: `\n' +
    '      .reveal-on-scroll, .wksc-reveal {\n' +
    '        opacity: 1 !important;\n' +
    '        visibility: visible !important;\n' +
    '        transform: none !important;\n' +
    '        filter: none !important;\n' +
    '        pointer-events: auto !important;\n' +
    '      }\n' +
    '    `\n' +
    '  });\n' +
    '\n' +
    '  // Verify the main header for House Types\n' +
    "  const heading = page.locator('h1.ht-headline');\n" +
    '  await (0, _test.expect)(heading).toBeVisible();\n' +
    '  await (0, _test.expect)(heading).toContainText(/Smart homes/i);\n' +
    '\n' +
    '  // Verify filter elements are present and visible\n' +
    "  await (0, _test.expect)(page.locator('select#filter-estate')).toBeVisible();\n" +
    "  await (0, _test.expect)(page.locator('select#filter-beds')).toBeVisible();\n" +
    "  await (0, _test.expect)(page.locator('select#filter-baths')).toBeVisible();\n" +
    "  await (0, _test.expect)(page.locator('select#filter-type')).toBeVisible();\n" +
    "  await (0, _test.expect)(page.locator('button#filter-reset')).toBeVisible();\n" +
    '\n' +
    '  // Either listings should load or the no-results/loading UI should display cleanly\n' +
    "  const grid = page.locator('#ht-grid');\n" +
    "  const noResults = page.locator('#ht-no-results');\n" +
    '  await (0, _test.expect)(grid.or(noResults).first()).toBeVisible();\n' +
    '}',
