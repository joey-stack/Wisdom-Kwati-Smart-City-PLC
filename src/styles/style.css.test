/* ========================================
   WISDOM KWATI LANDING PAGE — STYLE.CSS
   Based on Realist template layout
   ======================================== */

:root {
  /* Using WKSC brand colors from wksc-colors.css */
  --font-main: "Outfit", sans-serif;
  --ease-soft: cubic-bezier(0.7, 0, 0.3, 1);

  /* Advanced Responsive Tokens (2026 Standards) */
  --fluid-gap: clamp(2rem, 5vw, 5rem);
  --container-padding: 0;
  --safe-area-top: env(safe-area-inset-top, 0px);
  --safe-area-bottom: env(safe-area-inset-bottom, 0px);
  --safe-area-left: env(safe-area-inset-left, 0px);
  --safe-area-right: env(safe-area-inset-right, 0px);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

a {
  text-decoration: none;
  color: inherit;
}

html,
body {
  overflow-x: hidden;
  width: 100%;
  position: relative;
  background: var(--bg-main);
  font-family: var(--font-main);
  color: var(--text-primary);
}

body.no-scroll {
  overflow: hidden !important;
}

/* ========================
   NAVIGATION
   ======================== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 80px;
  background: transparent !important; /* Housing div remains strictly transparent */
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.nav-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  max-width: 1380px;
  height: clamp(56px, 8vh, 64px);
  background: var(--bg-main);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border);
  border-radius: 5px; /* Clean architectural geometric radius */
  padding: 0 10px;
  z-index: 20;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
  position: relative;
  transition: all 0.4s var(--ease-soft);
}

.logo {
  position: absolute;
  left: 10px;
  width: 172px;
  height: 64px;
  padding: 10px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  cursor: pointer;
  text-decoration: none;
}

.logo svg {
  height: 100%;
  width: auto;
}

.nav-links {
  display: flex;
  gap: 40px;
  list-style: none;
}

.nav-links li a {
  text-decoration: none;
  font-family: "Outfit", sans-serif;
  color: var(--text-primary);
  font-weight: 600;
  font-size: 14px;
  line-height: 1.4; /* Standardized to match flip-text height and prevent jitter */
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: flex; /* Flex layout to keep arrow on the same line */
  align-items: center;
  gap: 8px; /* Precise gap between text and chevron */
  padding: 20px 0; /* Expanded hit area for hover longevity into dropdown */
}

.nav-item.has-dropdown {
  position: static;
}

/* Restoration: Pixel-Perfect Center Lock (1380px Sync) */
.mega-menu-wrapper {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100%;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
  transition:
    opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
    visibility 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 10; /* Lowered below nav-container but above page content */
}

/* Hover Bridge: Deep overlap handover from nav link to menu */
.mega-menu::before {
  content: "";
  position: absolute;
  top: -40px; /* Refined overlap to prevent blocking neighboring links */
  left: 0;
  width: 100%;
  height: 45px; /* Standardized hit area */
  background: transparent;
  z-index: 10;
}

/* Refined Hover Logic: Opening triggered by nav link; Keep-open maintained by link OR black box */
.navbar:has(.house-trigger:hover) .house-types-menu,
.navbar:has(.projects-trigger:hover) .projects-menu,
.house-types-menu:has(.mega-menu:hover),
.projects-menu:has(.mega-menu:hover) {
  visibility: visible;
  opacity: 1;
}

.mega-menu {
  position: relative;
  top: 4px; /* Narrow architectural gap for tighter integration */
  width: 1380px; /* PIXEL-PERFECT 1380PX SYNC */
  margin: 0 auto; /* STABLE MERCATOR CENTERING */
  background: #000000;
  backdrop-filter: blur(
    20px
  ); /* Optimized from 25px for better GPU performance */
  -webkit-backdrop-filter: blur(20px);
  will-change: transform, clip-path; /* Pre-promote to composite layer */
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  padding: 40px;
  transform: translateY(-10px) translateZ(0); /* Cinematic unfold from top downwards */
  clip-path: inset(
    -30% -30% 100% -30%
  ); /* Fully masked from bottom, shadow spills allowed */
  transition:
    transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
    clip-path 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  pointer-events: auto;
  backface-visibility: hidden;
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.navbar:has(.house-trigger:hover) .house-types-menu .mega-menu,
.house-types-menu:has(.mega-menu:hover) .mega-menu,
.navbar:has(.projects-trigger:hover) .projects-menu .mega-menu,
.projects-menu:has(.mega-menu:hover) .mega-menu {
  transform: translateY(0) translateZ(0); /* Perfectly synced landing */
  clip-path: inset(
    -30% -30% -30% -30%
  ); /* Fully revealed with safe shadow bleed */
}
/* Chevron Flip Animation */
.dropdown-arrow {
  transition:
    transform 0.45s cubic-bezier(0.645, 0.045, 0.355, 1),
    opacity 0.45s cubic-bezier(0.645, 0.045, 0.355, 1);
  opacity: 0.5;
}

.nav-item:hover .dropdown-arrow {
  transform: rotate(180deg);
  opacity: 1;
}

.mega-menu-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 40px; /* Matching inspector data */
}

.mega-menu-grid,
.mega-menu-grid-4,
.mega-menu-grid-5 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  width: 100%;
}

.mega-menu-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px 40px;
  width: 100%;
}

.mega-menu-grid-4 .mega-menu-card:nth-child(4n) {
  border-right: none;
}

.mega-menu-grid-5 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px 40px;
  width: 100%;
}

.mega-menu-grid-5 .mega-menu-card {
  grid-column: auto;
}

.mega-menu-grid-5 .mega-menu-card:nth-child(3n) {
  border-right: none;
}

/* Cinematic Focus Effect */
.mega-menu-grid:hover .mega-menu-card,
.mega-menu-grid-4:hover .mega-menu-card,
.mega-menu-grid-5:hover .mega-menu-card {
  filter: blur(4px) brightness(0.7);
  opacity: 0.6;
}

.mega-menu-grid .mega-menu-card:hover,
.mega-menu-grid-4 .mega-menu-card:hover,
.mega-menu-grid-5 .mega-menu-card:hover {
  filter: blur(0) brightness(1);
  opacity: 1;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* 4-column dense grid for 22+ items */
  gap: 32px 24px;
  width: 100%;
}

.project-item {
  display: flex;
  align-items: center;
  gap: 16px;
  text-decoration: none;
  transition: all 0.4s var(--ease-soft);
}

.project-item img {
  width: 64px;
  height: 64px;
  border-radius: 8px;
  object-fit: cover;
  filter: brightness(0.8);
  transition: all 0.4s var(--ease-soft);
}

.project-item-content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.project-item h4 {
  font-family: var(--font-header);
  font-size: 15px;
  font-weight: 600;
  color: #fff8ed;
  margin: 0;
}

.project-item span {
  font-size: 11px;
  color: rgba(255, 248, 237, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Cinematic Focus for Projects */
.projects-grid:hover .project-item {
  filter: blur(2px) grayscale(0.5);
  opacity: 0.4;
}

.projects-grid .project-item:hover {
  filter: blur(0) grayscale(0);
  opacity: 1;
  transform: translateX(5px);
}

.projects-grid .project-item:hover img {
  filter: brightness(1.1);
  box-shadow: 0 5px 15px rgba(187, 227, 57, 0.2);
}

.mega-menu-card {
  position: relative;
  height: auto; /* Shrink to fit content */
  background: transparent;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column; /* Restored Vertical Layout */
  padding: 24px; /* Balanced spacing */

  /* Sequential Fade-in Setup */
  opacity: 0;
  transform: translateY(15px);
  transition:
    opacity 0.3s var(--ease-soft),
    transform 0.3s var(--ease-soft),
    background-color 0.4s var(--ease-soft);
}

/* Card Reveals when Wrapper becomes Visible */
/* We target the opened states of the menu to show the cards */
.navbar:has(.house-trigger:hover) .mega-menu-card,
.house-types-menu:has(.mega-menu:hover) .mega-menu-card,
.navbar:has(.projects-trigger:hover) .mega-menu-card,
.projects-menu:has(.mega-menu:hover) .mega-menu-card {
  opacity: 1;
  transform: translateY(0);
}

/* Precise Staggering (Unfolds bg for 0.4s, then cards pop in) */
.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(1),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(1),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(1),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(1) {
  transition-delay: 0.3s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(2),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(2),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(2),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(2) {
  transition-delay: 0.35s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(3),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(3),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(3),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(3) {
  transition-delay: 0.4s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(4),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(4),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(4),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(4) {
  transition-delay: 0.45s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(5),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(5),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(5),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(5) {
  transition-delay: 0.5s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(6),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(6),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(6),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(6) {
  transition-delay: 0.55s;
}

.navbar:has(.house-trigger:hover) .mega-menu-card:nth-child(7),
.house-types-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(7),
.navbar:has(.projects-trigger:hover) .mega-menu-card:nth-child(7),
.projects-menu:has(.mega-menu:hover) .mega-menu-card:nth-child(7) {
  transition-delay: 0.6s;
}

.mega-menu-card:not(:last-child) {
  border-right: 1px dashed rgba(124, 95, 255, 0.3); /* Restored dashed separator */
}

.mega-menu-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: visible; /* Allow shadow to breathe */
  background: transparent; /* Minimalist integration */
  transition: all 0.5s var(--ease-soft);
  display: flex;
  flex-direction: column;
}

/* Card hover state simplified for architectural stability */

.card-image {
  position: relative;
  width: 100%;
  height: 140px; /* Restored dimension */
  z-index: 1;
  overflow: hidden;
  border-radius: 6px;
}

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.9);
  transition: transform 0.8s var(--ease-soft);
}

.mega-menu-card:hover .card-image img {
  /* Scaling removed per stability request */
  filter: brightness(1.1);
}

/* Divider removed per high-fidelity reference */
.card-divider {
  display: none;
}

.card-content {
  position: relative;
  width: 100%;
  padding: 0; /* Removed top padding as image is gone */
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex-grow: 1;
}

.card-content h3 {
  color: #fff8ed;
  font-size: 16px; /* Concise scale */
  font-weight: 600;
  letter-spacing: -0.01em;
  margin: 0;
}

.card-content p {
  color: rgba(255, 248, 237, 0.6);
  font-size: 13px;
  line-height: 1.4;
  margin: 0;
  max-width: 320px;
}

.card-link {
  color: var(--accent-green);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-top: 8px;
}

.card-link svg {
  transition: transform 0.3s ease;
}

.mega-menu-card:hover .card-link svg {
  transform: translateX(4px);
}

.flip-text {
  position: relative;
  display: inline-block; /* More stable layout for flex parents */
  vertical-align: top;
  overflow: hidden;
  height: 1.4em;
  line-height: 1.4em;
}

.flip-text span {
  display: block;
  height: 1.4em;
  line-height: 1.4em;
  transition: transform 0.45s cubic-bezier(0.645, 0.045, 0.355, 1); /* Premium Ease-in-out-sine */
  will-change: transform;
  backface-visibility: hidden; /* Prevent sub-pixel jitter */
  transform: translateZ(0); /* Force GPU Hardware Layer */
}

.flip-text span:last-child {
  position: absolute;
  top: 100%;
  left: 0;
}

.nav-links li a:hover .flip-text span {
  transform: translateY(-100%);
}

.nav-cta {
  position: absolute;
  right: 10px;
  background: var(--accent-green);
  color: var(--text-primary);
  border: none;
  padding: 13px 26px; /* Elongated pill shape */
  border-radius: 5px;
  font-size: 14px;
  font-weight: 600;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  line-height: normal;
  letter-spacing: 0.1em;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.4s var(--ease-soft);
  white-space: nowrap;
  will-change: transform, background, box-shadow;
}

.nav-cta:hover {
  background: var(--accent-green);
  opacity: 0.9;
  box-shadow: var(--shadow-soft);
}

.nav-cta:hover .flip-text span {
  transform: translateY(-100%);
}

.nav-cta svg {
  margin-left: 8px;
  transition: transform 0.3s ease;
}

.nav-cta:hover svg {
  transform: translateX(3px);
}

/* Mobile Toggle - Minimalist 2-line */
.menu-toggle {
  display: none; /* Desktop hidden */
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  gap: 6px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 1001;
}

.hamburger-line {
  display: block;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: all 0.4s var(--ease-soft);
}

.line-1 {
  width: 24px;
}
.line-2 {
  width: 16px;
}

/* Mobile Menu Overlay */
.mobile-menu-overlay {
  display: none; /* Explicitly hidden on desktop */
  position: fixed;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  background: var(--bg-main);
  z-index: 2000;
  transform: translateX(100%);
  transition: transform 0.8s var(--ease-soft);
  flex-direction: column;
  padding: 60px 40px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
@media (max-width: 1024px) {
  .mobile-menu-overlay {
    display: flex;
  }
}

.mobile-menu-overlay::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(to right, rgba(26, 26, 26, 0.03) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(26, 26, 26, 0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
  z-index: -1;
}

body.menu-active .mobile-menu-overlay {
  transform: translateX(0);
}

.menu-close {
  position: absolute;
  top: 30px;
  right: 30px;
  background: transparent;
  border: none;
  font-size: 32px;
  color: var(--text-primary);
  cursor: pointer;
  transition: transform 0.6s var(--ease-soft);
  will-change: transform;
}

body.menu-active .menu-close {
  transform: rotate(90deg);
}

.mobile-menu-content {
  margin-top: 80px;
  display: flex;
  flex-direction: column;
  gap: 60px;
}

.mobile-nav-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.mobile-nav-links li {
  opacity: 0;
  transform: translateX(30px);
  transition:
    opacity 0.8s var(--ease-soft),
    transform 0.8s var(--ease-soft);
  will-change: transform, opacity;
}

body.menu-active .mobile-nav-links li {
  opacity: 1;
  transform: translateX(0);
}

/* Staggered Delay (Terge) */
body.menu-active .mobile-nav-links li:nth-child(1) {
  transition-delay: 0.1s;
}
body.menu-active .mobile-nav-links li:nth-child(2) {
  transition-delay: 0.2s;
}
body.menu-active .mobile-nav-links li:nth-child(3) {
  transition-delay: 0.3s;
}
body.menu-active .mobile-nav-links li:nth-child(4) {
  transition-delay: 0.4s;
}

.mobile-nav-links a {
  font-family: "Outfit", sans-serif;
  font-size: 42px;
  font-weight: 600;
  color: var(--text-primary);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: -0.04em;
  display: flex;
  align-items: center;
  gap: 16px;
  transition: color 0.3s ease;
}

.mobile-nav-links a::after {
  content: "";
  width: 0;
  height: 8px;
  background: var(--accent-green);
  border-radius: 50%;
  transition: width 0.4s var(--ease-soft);
}

.mobile-nav-links a:hover {
  color: var(--accent-green);
}

.mobile-nav-links a:hover::after {
  width: 8px;
}

/* Mobile Accordion & High-Density Flow */
.mobile-nav-item .dropdown-arrow {
  margin-left: auto;
  width: 14px;
  height: 14px;
  transition: transform 0.4s var(--ease-soft);
  opacity: 0.5;
}

.mobile-nav-item.expanded .dropdown-arrow {
  transform: rotate(180deg);
  opacity: 1;
}

.mobile-accordion-content {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-top: 0;
}

.mobile-nav-item.expanded .mobile-accordion-content {
  max-height: 1500px;
  opacity: 1;
  padding-top: 24px;
  padding-bottom: 20px;
}

.mobile-compact-card {
  display: flex;
  align-items: center;
  gap: 16px;
  text-decoration: none;
  padding: 16px 0;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.mobile-compact-card:last-child {
  border-bottom: none;
}

.mobile-compact-card:active {
  opacity: 0.7;
}

.compact-thumb {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  object-fit: cover;
  filter: brightness(0.8);
}

.compact-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.compact-info h4 {
  font-size: 14px;
  font-family: var(--font-header);
  color: #fff8ed;
  margin: 0;
}

.compact-info p {
  font-size: 11px;
  color: rgba(255, 248, 237, 0.5);
  margin: 0;
  line-height: 1.3;
}

/* Tablet (2-Column Grid) Logic */
@media (min-width: 768px) {
  .mobile-accordion-content {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}

.mobile-cta {
  background: var(--accent-green);
  color: var(--text-primary);
  border: none;
  padding: 20px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-weight: 600;
  font-size: 14px;
  line-height: normal;
  letter-spacing: 0.1em;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
}

/* Ensure flip text works on mobile CTA too */
.mobile-cta .flip-text {
  height: 18px;
  overflow: hidden;
  position: relative;
  display: block;
}

.mobile-cta .flip-text span {
  display: block;
  transition: transform 0.5s var(--ease-soft);
}

.mobile-cta:hover .flip-text span {
  transform: translateY(-100%);
}
.mobile-cta {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.8s var(--ease-soft);
  transition-delay: 0.5s;
}

body.menu-active .mobile-cta {
  opacity: 1;
  transform: translateY(0);
}

.nav-cta svg {
  transition: transform 0.3s ease;
  margin-left: 2px;
}

.nav-cta:hover svg {
  transform: translateX(2px);
}

/* ========================
   HERO SECTION
   ======================== */
.hero {
  position: relative;
  height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  background: url("/assets/hero_bg.webp") no-repeat center center/cover;
  overflow: hidden;
  padding: 0;
}

.hero::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.2) 0%,
    rgba(0, 0, 0, 0.6) 100%
  );
  z-index: 1;
}

.hero-container {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: flex-start; /* Reverted to top-alignment for balanced layout */
  width: 100%;
  max-width: 1380px;
  padding: 140px 0 100px 0; /* Expanded headroom for 120px headline */
  align-self: center;
}

/* Grid Overlay Overlay */
.grid-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(to right, rgba(26, 26, 26, 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(26, 26, 26, 0.05) 1px, transparent 1px);
  background-size: 100px 100px; /* Adjust grid size */
  z-index: 1;
  pointer-events: none;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
  gap: 24px;
  max-width: 800px;
}

.hero-tag {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 6px 14px;
  border-radius: 100px;
  color: var(--bg-main);
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.dot {
  width: 6px;
  height: 6px;
  background: var(--accent-green);
  border-radius: 50%;
  box-shadow: 0 0 10px var(--accent-green);
}

.headline {
  font-family: Inter, "Inter Placeholder", sans-serif;
  font-size: clamp(48px, 8vw, 110px);
  font-weight: 500;
  letter-spacing: -0.04em;
  color: var(--bg-main);
  line-height: 121px; /* Precise 1.1 ratio for 110px scale */
  margin-bottom: 0;
  text-transform: uppercase;
  text-align: left;
  max-width: 950px;
}

.hero-card .subheadline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 18px;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: var(--bg-main);
  max-width: 100%;
  line-height: 1.6;
  text-transform: uppercase; /* Reverting to uppercase for architectural punch */
  opacity: 0.85;
  text-align: left;
  margin-bottom: 15px;
}

.highlight {
  background: rgba(187, 227, 57, 0.15); /* Brand Green with subtle opacity */
  backdrop-filter: blur(10px);
  padding: 6px 16px;
  border-radius: 8px;
  white-space: nowrap;
}

.cta-button {
  margin-top: 10px; /* Reduced for card integration */
  background: var(--accent-green);
  color: var(--text-primary);
  border: none;
  padding: 18px 36px;
  font-size: 14px;
  font-weight: 600;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  line-height: normal;
  letter-spacing: 0.1em;
  border-radius: 5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center; /* Center-aligned text and icon */
  gap: 12px;
  transition:
    background 0.6s var(--ease-soft),
    opacity 0.6s var(--ease-soft),
    box-shadow 0.6s var(--ease-soft);
}

.cta-button:hover {
  background: var(--accent-green);
  opacity: 0.9;
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
}

.cta-button:hover .flip-text span {
  transform: translateY(-100%);
}

.cta-button svg {
  transition: transform 0.3s ease;
}

.cta-button:hover svg {
  transform: translateX(5px);
}

/* Glassmorphism Panels */
.glass-panel {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 5px;
  padding: 10px; /* Adjusted per user request */
}

.hero-card {
  width: 450px;
  display: flex;
  flex-direction: column;
  gap: 15px;
  text-align: left;
  margin-bottom: 20px; /* Slight offset from bottom */
}

.mission-header {
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 700;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--bg-main);
}

.mission-card p {
  font-size: 15px;
  line-height: 1.6;
  color: var(--bg-main);
  opacity: 0.85;
}

.learn-more {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--bg-main);
  text-decoration: none;
  font-weight: 600;
  font-size: 14px;
  transition: opacity 0.3s ease;
}

.learn-more:hover {
  opacity: 0.7;
}

.learn-more svg {
  transition: transform 0.3s ease;
}

.learn-more:hover svg {
  transform: translateX(4px);
}

/* ========================
   WHO WE ARE SECTION
   ======================== */
.who-we-are {
  padding: 120px 0;
  background: var(--bg-main);
  position: relative;
  z-index: 10;
}

.who-container {
  max-width: 1380px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: clamp(1.5rem, 4vw, 3rem); /* Reduced for tighter layout */
  padding: 0; /* Padding removed site-wide */
}

.who-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  height: fit-content;
  padding-top: 16px;
}

.who-label .label-square {
  width: 12px; /* Scaled down for premium minimal feel */
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px; /* Precise rounding */
}

.who-content {
  display: flex;
  flex-direction: column;
  gap: 20px; /* Concise vertical rhythm */
  max-width: 800px;
}

.who-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 52.8px;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  margin: 0;
}

.who-text {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 16px;
  font-weight: 500;
  line-height: 22.4px;
  color: var(--text-secondary);
  max-width: 640px;
  margin: 0;
  opacity: 0.85; /* Increased for better presence at 16px */
}

.btn-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  padding: 13px 26px; /* Matched to Navbar for a more minimal, technical look */
  gap: 10px; /* Precise gap for centered alignment */
  background: var(--accent-green);
  color: var(--text-primary);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  font-weight: 600;
  font-size: 14px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  line-height: normal;
  transition: all 0.4s var(--ease-soft);
  letter-spacing: 0.1em;
  white-space: nowrap;
}

.btn-pill:hover {
  background: var(--accent-green);
  opacity: 0.9;
  box-shadow: var(--shadow-soft);
}

.btn-pill .flip-text {
  height: 18px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

.btn-pill .flip-text span {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 18px; /* Matched to parent height for perfect centering */
  transition: transform 0.5s var(--ease-soft);
  color: var(--text-primary);
  line-height: 1; /* Reset for flex alignment */
}
.btn-pill:hover .flip-text span {
  transform: translateY(-100%);
}

/* Base Container Utility */
.container-1380 {
  max-width: 1380px;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
}

/* ========================
   RESPONSIVE TYPOGRAPHY & LAYOUT UTILS
   ======================== */

/* ========================
   HOUSE PORTFOLIO SECTION
   ======================== */
.house-portfolio {
  padding: 120px 0;
  background: var(--bg-main);
}

.section-line {
  max-width: 1380px;
  margin: 0 auto 64px; /* Matches header margin for symmetry */
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}

.portfolio-container-main {
  max-width: 1380px;
  width: 100%;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

.portfolio-header {
  margin-bottom: 80px; /* Synchronized cinematic gap */
}

.sidebar-layout {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: clamp(2rem, 5vw, 5rem);
  width: 100%;
  position: relative;
  align-items: start;
}

.section-main-content {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.section-line {
  width: 100%;
  margin-bottom: 32px;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.portfolio-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  height: fit-content;
  padding-top: 16px;
}

.portfolio-label .label-square {
  width: 12px;
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px;
}

.portfolio-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 52.8px;
  color: var(--text-primary);
  max-width: 800px;
  letter-spacing: -0.01em;
  margin: 0;
}

.portfolio-grid {
  max-width: 1380px;
  width: 100%;
  margin: 0 auto;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 60px 40px;
}

.property-card {
  display: flex;
  flex-direction: column;
  gap: 24px;
  text-decoration: none;
  transition: transform 0.4s var(--ease-soft);
}

.property-image {
  position: relative;
  width: 100%;
  height: 380px;
  border-radius: 5px;
  overflow: hidden;
  background: var(--bg-section);
  outline: 2px solid transparent;
  transition: outline-color 0.4s var(--ease-soft);
}

.property-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--ease-soft);
}

.property-card:hover .property-image {
  outline-color: var(--accent-green);
}

.property-card:hover .property-image img {
  transform: scale(1.08);
}

.property-info {
  display: flex;
  flex-direction: column;
  gap: 12px; /* Concise architectural spacing */
}

.property-tag {
  position: absolute;
  top: 16px;
  right: 16px;
  padding: 6px 14px;
  border-radius: 100px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  z-index: 5;
}

.tag-sale {
  background: #e1efd8; /* Exact screenshot match */
  color: #4a683a;
}

.tag-rent {
  background: #ffebd2;
  color: #8c5d26;
}

.property-location {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 600;
  color: #555;
  font-family: "Inter", sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.property-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08); /* Architectural divider */
}

.stats-group {
  display: flex;
  align-items: center;
  gap: 10px;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-primary);
  font-family: "Inter", sans-serif;
}

.stat-dot {
  width: 3px;
  height: 3px;
  background: var(--text-secondary);
  border-radius: 50%;
  opacity: 0.5;
}

.property-price {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  font-family: "Inter", sans-serif;
}

.property-description {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 20px;
  font-weight: 500;
  line-height: 26px;
  color: #21201b;
  max-width: 450px;
  margin: 4px 0 0 0;
  letter-spacing: -0.01em;
  /* Framer Standard: 2-line wrap with truncation */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.portfolio-footer {
  display: flex;
  justify-content: center;
  margin-top: 64px;
}

/* ========================
   RESPONSIVENESS
   ======================== */

/* Large Tablets / Small Desktops */
@media (max-width: 1200px) {
  .headline {
    font-size: clamp(3rem, 7.5vw, 80px);
  }
  .hero-container {
    gap: 40px;
  }
}

/* Medium Tablets & Below */
@media (max-width: 1024px) {
  .nav-links,
  .nav-cta,
  .mega-menu {
    display: none !important;
  }

  .menu-toggle {
    display: flex !important;
    position: absolute;
    right: 24px;
  }

  .nav-container {
    padding: 0 24px;
  }

  .who-container {
    grid-template-columns: 1fr;
    gap: 20px; /* Reduced vertical gap between label and content */
    padding: 0 32px;
  }

  .who-label {
    padding-top: 0;
    margin-bottom: 0; /* Let grid gap handle the spacing */
  }

  .who-headline {
    font-size: 1.6rem; /* Scaled down for mobile architectural elegance */
    line-height: 1.3;
  }

  .portfolio-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .sidebar-layout {
    grid-template-columns: 1fr;
    gap: 0;
    padding: 0 32px;
  }

  .portfolio-label,
  .neighborhood-label,
  .background-label,
  .history-label,
  .team-label,
  .differences-label,
  .services-label,
  .uniqueness-label,
  .reviews-label,
  .process-label,
  .blog-label,
  .faq-label {
    margin-bottom: 0; /* Standardized to rely on container gap */
    padding-top: 0;
  }

  .portfolio-headline,
  .neighborhood-headline,
  .background-headline,
  .team-headline {
    margin-bottom: 32px;
    max-width: 100%;
  }

  .hero-container {
    padding: 0 32px 60px 32px;
  }
}

/* Mobile Devices */
@media (max-width: 768px) {
  .navbar {
    height: 72px;
    padding: 10px;
    background: transparent !important; /* Strictly transparent housing */
    border: none !important;
    box-shadow: none !important;
    display: flex;
    align-items: center;
  }

  .nav-container {
    height: 100% !important; /* Fill the padded navbar */
    padding: 0 10px !important;
    background: var(--bg-main) !important; /* Background moved to the inner navbar */
    border: 1px solid var(--border) !important;
    border-radius: 5px !important; /* Floating pill effect */
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05) !important;
  }

  .logo {
    width: 120px; /* Slimmer logo for narrow viewports */
    height: 40px;
    left: 10px;
    padding: 5px;
  }

  .hero {
    padding: 0;
    height: 100vh;
  }

  .hero-container {
    flex-direction: column;
    justify-content: center; /* Center content on mobile */
    align-items: center;
    text-align: center;
    gap: 24px;
    padding: 10px;
    margin-top: 0;
  }

  .portfolio-container-main {
    padding: 0 10px;
  }

  .portfolio-grid {
    grid-template-columns: 1fr;
    padding: 0; /* Handled by container */
    gap: 48px;
  }

  .portfolio-header {
    padding: 0; /* Handled by container */
    margin-bottom: 0; /* Standardized gap usage */
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .portfolio-headline {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .property-description {
    font-size: 18px;
    line-height: 24px;
  }

  .hero-content {
    align-items: center;
    text-align: center;
  }

  .headline {
    font-size: 2.2rem; /* Standardized mobile headline scale */
    text-align: center;
    line-height: 1.1;
    max-width: 100%;
    color: var(--bg-main);
  }

  .hero-card {
    max-width: 100%;
    text-align: center;
    align-items: center;
    padding: 10px; /* Tighter padding for mobile panels */
    gap: 12px;
  }

  .hero-card .subheadline {
    text-align: center;
    font-size: 15px;
  }

  .cta-button {
    width: 100%;
    justify-content: center;
    padding: 12px 24px;
  }

  .who-we-are {
    padding: 70px 0 0 0;
  }

  .who-container {
    padding: 0 10px;
  }

  h2 {
    font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
    font-size: 1.6rem !important;
    font-weight: 500 !important;
    line-height: 1.3 !important;
    letter-spacing: -0.01em !important;
  }

  /* Standardized Section Gaps for Mobile */
  .who-container,
  .portfolio-container-main,
  .neighborhood-container,
  .services-container,
  .uniqueness-container,
  .reviews-container,
  .process-container,
  .blog-container,
  .faq-container,
  .newsletter-container {
    gap: 20px !important;
  }

  .ht-card-info {
    flex-direction: column;
    gap: 16px;
    padding: 16px;
  }

  .ht-card-left,
  .ht-card-right {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left !important;
  }

  .ht-card-right {
    gap: 8px; /* More space between type and specs */
  }

  .ht-card-type {
    font-size: 14px;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
}

/* ========================
   CUSTOM CARD CURSOR
   ======================== */
.card-cursor {
  position: fixed;
  top: 0;
  left: 0;
  width: 110px; /* Restored from 85px for premium architectural impact */
  height: 110px;
  background: var(--accent-green);
  color: var(--text-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  pointer-events: none;
  z-index: 10000;
  opacity: 0;
  transform: translate(-50%, -50%) scale(0);
  transition:
    transform 0.3s var(--ease-soft),
    opacity 0.2s ease;
  font-family: "Inter", sans-serif;
  font-size: 11px; /* Scaled down typography for balance */
  font-weight: 900;
  letter-spacing: 0.12em;
}

.card-cursor.active {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.card-cursor span {
  margin-top: 1px;
}

/* Update media queries to hide custom cursor on touch devices */
@media (max-width: 1024px) {
  .card-cursor {
    display: none !important;
  }
}

/* ========================
   NEIGHBORHOOD SECTION
   ======================== */
.neighborhood-section {
  padding: 120px 0;
  background: var(--bg-main);
}

.neighborhood-container {
  max-width: 1380px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

.neighborhood-header {
  margin-bottom: 80px; /* Cinematic gap before grid */
}

.neighborhood-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  height: fit-content;
  padding-top: 16px;
}

.neighborhood-label .label-square {
  width: 12px;
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px;
}

.neighborhood-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 52.8px;
  color: var(--text-primary);
  max-width: 800px;
  letter-spacing: -0.01em;
}

.neighborhood-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 48px 32px;
  padding: 0;
}

.neighborhood-card {
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-decoration: none;
  position: relative;
  transition: transform 0.3s ease;
}

.neighborhood-image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 10;
  background: var(--bg-surface); /* Synched with footer background */
  padding: 10px;
  border: 1px solid rgba(0, 0, 0, 0.08); /* Synchronized border style */
  border-radius: 5px;
  box-shadow: none; /* Removed for a cleaner, flatter architectural aesthetic */
  overflow: hidden;
  transition:
    transform 0.4s var(--ease-soft),
    border-color 0.4s var(--ease-soft),
    box-shadow 0.4s var(--ease-soft);
}

.neighborhood-card:hover {
  border-color: var(--accent-green);
}

.neighborhood-image-inner {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 3px; /* Inner image radius */
}

.neighborhood-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--ease-soft);
}

.neighborhood-card:hover .neighborhood-image-inner img {
  transform: scale(1.08);
}

.neighborhood-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 4px;
}

.neighborhood-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.neighborhood-title {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 20px;
  font-weight: 500;
  line-height: 26px;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  margin: 0;
}

.neighborhood-location {
  font-family: var(--font-main);
  font-size: 13px;
  color: var(--text-secondary);
  opacity: 0.65;
  margin: 0;
}

.neighborhood-arrow {
  width: 26px;
  height: 26px;
  background: var(--bg-surface); /* Synched with footer background */
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
  transition: all 0.3s var(--ease-soft);
}

.neighborhood-card:hover .neighborhood-arrow {
  background: var(--accent-green);
  color: #000;
  border-color: var(--accent-green);
  transform: none; /* Removed horizontal shift for structural stability */
}

.neighborhood-footer {
  display: flex;
  justify-content: center;
  margin-top: 64px;
}

/* Enhanced Breakpoints for structural grouping */
@media (max-width: 1024px) {
  .neighborhood-container {
    padding: 0 32px;
  }

  .neighborhood-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }
}

@media (max-width: 768px) {
  .neighborhood-section {
    padding: 70px 0;
  }
  .neighborhood-container {
    padding: 0 10px;
    gap: 20px !important;
  }
  .neighborhood-header {
    padding: 0;
    margin-bottom: 0;
    grid-template-columns: 1fr; /* Force stacking on mobile */
    gap: 16px;
  }
  .neighborhood-grid {
    padding: 0;
    grid-template-columns: 1fr; /* Force single column on mobile */
    gap: 24px;
  }
  .neighborhood-headline {
    font-size: 1.8rem;
  }
}

/* Services Section */
.services-section {
  padding: 100px 0;
  width: 100%;
  position: relative;
  background: var(--bg-main);
}

.services-container {
  max-width: 1380px;
  margin: 0 auto;
  position: relative;
}

.services-header {
  margin-bottom: 80px;
}

.services-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  padding-top: 16px;
}

.services-label .label-square {
  width: 12px;
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px;
}

.services-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 52.8px;
  color: var(--text-primary);
  max-width: 800px;
  letter-spacing: -0.01em;
}

/* Services Grid Body */
.services-grid-body {
  display: grid;
  grid-template-columns: 1fr 1.15fr; /* Slight favor to the image for cinematic weight */
  gap: 80px;
  align-items: start;
}

.services-cards-stack {
  display: flex;
  flex-direction: column;
  gap: 20px; /* Precise gap between isolated cards */
}

.service-card {
  background: var(--bg-surface); /* Synched with footer background */
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 5px;
  padding: 32px 40px;
  display: flex;
  flex-direction: column; /* Supports vertical expansion */
  align-items: flex-start;
  cursor: pointer;
  transition:
    background 0.5s var(--ease-soft),
    border-color 0.5s var(--ease-soft),
    box-shadow 0.5s var(--ease-soft);
  overflow: hidden;
}

.service-card:hover {
  background: var(--accent-green); /* Brand-green hover state as requested */
  border-color: var(--accent-green);
}

.service-card-header {
  display: flex;
  align-items: center;
  gap: 32px;
  width: 100%;
}

.service-icon {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-primary);
  transition: all 0.4s var(--ease-soft);
  flex-shrink: 0;
}

.service-card:hover .service-card-title,
.service-card:hover .service-icon {
  color: #000; /* Ensuring high-contrast black on green */
}

.service-card:hover .service-icon {
  transform: scale(1.1);
}

.service-card-title {
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0;
  letter-spacing: -0.01em;
}

.service-card-body {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.5s var(--ease-soft);
  width: 100%;
}

.service-card:hover .service-card-body {
  max-height: 200px; /* Expands to show details */
  opacity: 1;
  margin-top: 24px;
}

.service-card-description {
  font-size: 1rem;
  line-height: 1.6;
  color: #000; /* High contrast on green */
  margin: 0;
  padding-left: 96px; /* Aligns description text with the title (64px icon + 32px gap) */
}

/* Services Image Column */
.services-image-wrapper {
  position: relative;
  width: 100%;
  height: 730px; /* Fixed cinematic height as requested */
  background: #fffff2;
  padding: 0; /* Removed architectural padding */
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 5px;
  overflow: hidden;
}

.services-image-inner {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.services-image-inner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Services Responsive */
@media (max-width: 1200px) {
  .services-grid-body {
    gap: 40px;
  }
}

@media (max-width: 1024px) {
  .services-container {
    padding: 0 32px;
  }

  .services-grid-body {
    grid-template-columns: 1fr; /* Stacking on tablet */
    gap: 60px;
  }

  .services-image-inner {
    min-height: 450px;
  }
}

@media (max-width: 768px) {
  .services-section {
    padding: 60px 0;
  }

  .services-header {
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }

  .service-item {
    flex-direction: column;
    gap: 16px;
    padding: 24px;
  }

  .service-title {
    font-size: 1.25rem;
  }

  .service-description {
    font-size: 0.95rem;
  }

  .services-image-inner {
    min-height: 350px;
  }
}
/* Uniqueness Section */
.uniqueness-section {
  padding: 120px 0;
  width: 100%;
  position: relative;
  background: var(--bg-main);
}

.uniqueness-container {
  max-width: 1380px;
  margin: 0 auto;
  padding: 0;
}

.uniqueness-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  padding-top: 16px;
}

.uniqueness-label .label-square {
  width: 12px;
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px;
}

.uniqueness-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 52.8px;
  color: var(--text-primary);
  max-width: 800px;
  letter-spacing: -0.01em;
}

.uniqueness-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  margin-top: 80px;
  align-items: stretch;
}

.uniqueness-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 480px; /* Spacious brutalist breathing room */
  padding: 0 0 0 24px;
  border-left: 1px solid rgba(0, 0, 0, 0.1); /* Structural vertical line */
  transition: border-color 0.4s var(--ease-soft);
}

.uniqueness-card:hover {
  border-color: var(--accent-green);
}

.uniqueness-pill {
  display: inline-block;
  background: var(--bg-section); /* Subtle surface background */
  padding: 10px 20px;
  border-radius: 50px;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.uniqueness-list-container {
  margin-top: auto;
}

.uniqueness-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.uniqueness-list li {
  font-size: 1rem;
  color: var(--text-secondary);
  padding: 16px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06); /* Thin horizontal separators */
  display: flex;
  align-items: center;
  gap: 12px;
  transition: color 0.3s ease;
}

.uniqueness-list li:last-child {
  border-bottom: none;
}

.uniqueness-list li::before {
  content: "";
  width: 6px;
  height: 6px;
  background: var(--accent-green); /* Brand-green square markers */
  flex-shrink: 0;
}

.uniqueness-card:hover .uniqueness-list li {
  color: var(--text-primary);
}

/* Uniqueness Responsive */
@media (max-width: 1200px) {
  .uniqueness-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 60px 40px;
  }
}

@media (max-width: 768px) {
  .uniqueness-grid {
    grid-template-columns: 1fr;
    gap: 60px;
  }

  .uniqueness-card {
    min-height: auto;
  }
}

/* ========================================
   REVIEWS SECTION — INFINITE CAROUSEL
   ======================================== */
.reviews-section {
  padding: 120px 0 40px; /* Reduced bottom padding for tighter transition */
  background: var(--bg-main);
  overflow: hidden; /* Prevent horizontal scrollbar on body */
}

.reviews-container {
  max-width: 1380px; /* Matched to process-container for architectural alignment */
  margin: 0 auto;
  padding: 0 40px;
}

.reviews-header {
  margin-bottom: 80px;
}

.reviews-label {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 12px;
  font-weight: 600;
  line-height: 18px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  height: fit-content;
  padding-top: 16px;
}

.reviews-label .label-square {
  width: 12px;
  height: 12px;
  background: var(--text-primary);
  border-radius: 3px;
}

.reviews-headline {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 1.1;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  margin: 0;
}

.carousel-wrapper {
  position: relative;
  width: 100vw;
  margin-left: calc(-50vw + 50%); /* Full bleed look */
  overflow: hidden;
  padding: 20px 0;
  perspective: 1000px; /* Enhanced 3D stability */
  -webkit-perspective: 1000px;
}

/* Optimized for Marquee flow */
.carousel-track {
  display: flex;
  gap: 32px;
  padding: 0;
  width: max-content; /* Ensure track spans full width of items */
  will-change: transform;
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
  perspective: 1000px;
}

/* Review Card - Base */
.review-card {
  flex: 0 0 386.66px;
  height: 517px;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  background: var(--bg-surface);
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  transition: transform 0.4s var(--ease-soft);
  cursor: pointer; /* Force regular pointer as per direct feedback */
  /* GPU Layer Promotion */
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}

/* NOTE: NEVER add the custom circle cursor (.card-cursor) to .review-card hover. 
   Per User Feedback: April 16, 2026. */

.review-card:hover {
  transform: translateY(0) translateZ(0); /* Explicitly zero out vertical movement */
  border-color: var(--accent-green);
}

/* Image Card Variant */
.review-card.image-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.review-card.image-card .card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40px 24px 24px;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.9) 0%,
    rgba(0, 0, 0, 0.4) 50%,
    transparent 100%
  );
  color: white;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  isolation: isolate;
}

/* Premium Cinematic Gradient Blur - Optimized */
.review-card.image-card .card-overlay::before {
  content: "";
  position: absolute;
  inset: 0;
  backdrop-filter: blur(
    20px
  ); /* Reduced from 25px for better GPU performance */
  -webkit-backdrop-filter: blur(20px);
  mask-image: linear-gradient(
    to top,
    black 0%,
    rgba(0, 0, 0, 0.8) 40%,
    transparent 80%
  );
  -webkit-mask-image: linear-gradient(
    to top,
    black 0%,
    rgba(0, 0, 0, 0.8) 40%,
    transparent 80%
  );
  z-index: -1;
  /* Force Hardware Layer */
  will-change: backdrop-filter;
  transform: translate3d(0, 0, 0);
}

.review-card.image-card .card-quote {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 20px;
  font-weight: 500;
  line-height: 26px;
  margin-bottom: 32px;
  border: none;
  padding: 0;
  font-style: normal;
  letter-spacing: -0.01em;
}

/* Standardized Identity Container (The "Brutalist Box") */
.reviewer-identity-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding-top: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
}

.text-card .reviewer-identity-container {
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.reviewer-meta-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.card-name {
  font-family: "Inter Display", "Inter Display Placeholder", sans-serif;
  font-size: 18px;
  font-weight: 600;
  line-height: 1.2;
  color: inherit;
}

.card-meta {
